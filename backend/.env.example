# Backend environment variables
# Copy to .env and fill in values for local dev (DATABASE_URL is optional locally)

# Postgres connection string from Supabase (Session mode, port 5432)
# Leave unset to use local SQLite instead
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Allowed origin for CORS. Set to your Vercel URL in production.
# Leave unset locally (all origins allowed).
# FRONTEND_URL=https://your-app.vercel.app
