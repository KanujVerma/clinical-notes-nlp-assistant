# Backend — set these as environment variables on Render (or locally in .env)

# Postgres connection string (Supabase session pooler recommended for Render free tier)
# Leave unset locally — falls back to SQLite
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# URL of the deployed frontend — used to restrict CORS in production
# Leave unset locally — defaults to allow all origins
FRONTEND_URL=https://your-app.vercel.app

# Frontend — set this as an environment variable on Vercel at build time
# VITE_ prefix is required for Vite to expose it to the browser bundle
VITE_API_BASE_URL=https://your-backend.onrender.com

# AI explainer — optional. If unset, the AI fallback is disabled.
ANTHROPIC_API_KEY=
